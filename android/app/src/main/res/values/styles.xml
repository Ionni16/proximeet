<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Tema splash: sfondo navy, status bar e nav bar scure -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:statusBarColor">#060D1A</item>
        <item name="android:navigationBarColor">#060D1A</item>
        <item name="android:forceDarkAllowed">false</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">false</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>
    <!-- Tema normale: si applica quando Flutter ha disegnato il primo frame -->
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">#060D1A</item>
        <item name="android:statusBarColor">#060D1A</item>
        <item name="android:navigationBarColor">#060D1A</item>
    </style>
</resources>
