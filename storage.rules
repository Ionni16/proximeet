rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────────
// ProxiMeet — Firebase Storage Security Rules
//
// Unico contenuto su Storage: le foto profilo, in avatars/{uid}.jpg.
// Ogni utente può scrivere SOLO il proprio file; la lettura è aperta agli
// utenti autenticati (gli avatar compaiono in nearby, wallet e richieste).
// L'eliminazione lato server (deleteAccount) usa l'Admin SDK e bypassa
// queste regole.
// ─────────────────────────────────────────────────────────────────────────────

service firebase.storage {
  match /b/{bucket}/o {

    match /avatars/{fileName} {
      allow read: if request.auth != null;

      allow write: if request.auth != null
        && fileName == request.auth.uid + '.jpg'
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');

      allow delete: if request.auth != null
        && fileName == request.auth.uid + '.jpg';
    }

    // Tutto il resto è negato.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
